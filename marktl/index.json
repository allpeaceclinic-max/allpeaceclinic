      "canonicalUrl": "https://allpeaceclinic-max.github.io/allpeaceclinic/marktl/%EC%9A%B0%EB%A6%AC%ED%8E%B8%ED%8E%B8%ED%96%A5_%ED%82%A4%EC%8A%A4%EC%8A%A4%ED%83%80%EB%85%B8%EB%B9%84%EC%B9%98/",
